        <h1>Hi, I'm <span class="home-name-box"><span class="home-name-text">AloftVox</span></span></h1>
        <p class="home-role">
          <span class="dynamic-role" data-role-text>{heroRoles[0]}</span><span class="type-caret" aria-hidden="true"></span>
        </p>
        <div class="button-row home-actions">
          <a class="button primary-button" href="https://github.com/AloftVox" target="_blank" rel="noreferrer">
