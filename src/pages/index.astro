  .home-card-section:last-of-type {
    margin-bottom: 36px;
  }

  .home-actions .button {
    min-width: 106px;
    min-height: 42px;
    border-radius: 999px;
    font-size: 0.94rem;
    font-weight: 700;
    gap: 8px;
  }

  .button-icon {
    width: 1.08em;
    height: 1.08em;
    fill: currentColor;
    flex: 0 0 auto;
  }

  .primary-button {
    border-color: rgba(90, 155, 216, 0.5);
    background: var(--color-accent);
    color: #ffffff;
  }

  .primary-button:hover {
    border-color: var(--color-accent-strong);
    background: var(--color-accent-strong);
    color: #ffffff;
  }

  .home-actions .button:not(.primary-button) {
    border-color: var(--color-line);
    background: var(--color-surface);
  }

  .home-actions .button:not(.primary-button):hover {
    border-color: rgba(79, 143, 216, 0.28);
    background: var(--color-accent-soft);
    color: var(--color-accent-strong);
  }

  .profile-mark {
    position: relative;
    --profile-size: 268px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--profile-size);
    height: var(--profile-size);
    margin: 0 auto;
    border-radius: 50%;
    isolation: isolate;
  }

