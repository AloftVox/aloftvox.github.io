---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import CategorySection from "../components/home/CategorySection.astro";
import FeaturedProject from "../components/home/FeaturedProject.astro";
import HeroTransition from "../components/home/HeroTransition.astro";
import OrbitHero from "../components/home/OrbitHero.astro";
import RecentPosts from "../components/home/RecentPosts.astro";
import SubscribeSection from "../components/home/SubscribeSection.astro";
import {
  buildHomeOrbitNodes,
  demoArticles,
  featuredProject,
  homeHeroRoles,
  homeIntroLines,
  homeSocialLinks,
  orbitCategories,
  previewByNode,
  type HomeArticle,
} from "../data/home";
import { getPostUrl, sortPosts } from "../lib/posts";

const allPosts = sortPosts(await getCollection("blog"));
const categoryPresentation = {
  development: { name: "Web Development", id: "web-development", color: "#64a8ff" },
  research: { name: "Deep Dives", id: "deep-dives", color: "#e6b85c" },
  notes: { name: "Life & Thinking", id: "life-thinking", color: "#e2bb66" },
} as const;

const realArticles: HomeArticle[] = allPosts.map((post) => {
  const category = categoryPresentation[post.data.category];
  const wordEstimate = `${post.data.title}${post.data.description}`.length;
  return {
    id: post.id,
    title: post.data.title,
    category: category.name,
    categoryId: category.id,
    date: post.data.pubDate.toISOString().slice(0, 10),
    readingTime: `${Math.max(5, Math.ceil(wordEstimate / 36))} min read`,
    tags: post.data.tags,
    href: getPostUrl(post),
    color: category.color,
    description: post.data.description,
  };
});

const recentArticles = [...realArticles, ...demoArticles]
  .filter((article, index, collection) => collection.findIndex((candidate) => candidate.id === article.id) === index)
  .slice(0, 6);

const orbitNodes = buildHomeOrbitNodes();
---

<BaseLayout
  title="AloftVox Orbit Library"
  description="AloftVox 的交互式知识星图：浏览文章、分类、项目和技术实验。"
>
  <div class="home-page">
    <OrbitHero
      orbitNodes={orbitNodes}
      socialLinks={homeSocialLinks}
      introLines={homeIntroLines}
      heroRoles={homeHeroRoles}
      nodePreviews={previewByNode}
    />
    <HeroTransition />
    <RecentPosts articles={recentArticles} />
    <CategorySection categories={orbitCategories} />
    <FeaturedProject project={featuredProject} />
    <SubscribeSection />
  </div>
</BaseLayout>

<style>
  .home-page {
    overflow: hidden;
    background: #fbfaf7;
  }

  :global(.home-page + .site-footer) {
    background: #fbfaf7;
  }
</style>
