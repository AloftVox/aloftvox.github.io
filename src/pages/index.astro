---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostList from "../components/PostList.astro";
import { blogCategories } from "../data/categories";
import { sortPosts } from "../lib/posts";

const allPosts = sortPosts(await getCollection("blog"));
const recentPosts = allPosts.slice(0, 4);
const countByCategory = new Map(
  blogCategories.map((category) => [
    category.key,
    allPosts.filter((post) => post.data.category === category.key).length,
  ]),
);

const categoryEntries = [
  {
    title: "技术文章",
    href: "/blog/",
    count: allPosts.length,
    description: "全部技术文章、项目记录与阶段性复盘。",
  },
  {
    title: "开发记录",
    href: "/blog/category/development/",
    count: countByCategory.get("development") ?? 0,
    description: "工程实践、代码安全、工具开发与实现细节。",
  },
  {
    title: "科研探索",
    href: "/blog/category/research/",
    count: countByCategory.get("research") ?? 0,
    description: "实验观察、问题记录与研究方向整理。",
  },
  {
    title: "学习笔记",
    href: "/blog/category/notes/",
    count: countByCategory.get("notes") ?? 0,
    description: "课程、实训、阅读和技术学习中的笔记。",
  },
];

const projects = [
  {
    title: "CodeGuard Tutor",
    description: "面向初学开发者的 VS Code 代码安全学习插件。",
    href: "/projects/codeguard-tutor/",
  },
];

// 首页动态打字文案：以后只改这里的字符串即可。
const heroRoles = [
  "静心得意，天下迎春",
  "人生海海，山山而川",
  "AI-assisted Development Explorer",
  "To be strong enough to gentle",
];

// 数值越大越慢，单位是毫秒。
const typingConfig = {
  typeDelay: 125,
  deleteDelay: 90,
  holdDelay: 1900,
};
---

