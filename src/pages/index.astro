  <section class="site-shell section-block home-card-section">
    <div class="section-title-row">
      <h2>最近更新</h2>
      <a class="text-link" href="/blog/">查看全部</a>
    </div>
    <PostList posts={recentPosts} />
  </section>

  <section class="site-shell section-block home-card-section">
    <h2>分类入口</h2>
    <div class="category-grid">
      {
        categoryEntries.map((category) => (
          <a class="category-entry" href={category.href}>
            <div>
              <h3>{category.title}</h3>
              <p>{category.description}</p>
            </div>
            <span>{category.count} 篇</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="site-shell section-block projects-preview home-card-section">
    <div class="section-title-row">
      <h2>项目</h2>
      <a class="text-link" href="/projects/">项目列表</a>
    </div>
    <ul class="project-rows">
      {
        projects.map((project) => (
          <li>
            <a href={project.href}>
              <strong>{project.title}</strong>
              <span>{project.description}</span>
              <span aria-hidden="true">→</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<script
  id="home-role-data"
  type="application/json"
  set:html={JSON.stringify({ roles: heroRoles, typing: typingConfig })}
/>

<script>
  const roleElement = document.querySelector("[data-role-text]");
  const roleDataElement = document.getElementById("home-role-data");
  const roleData = roleDataElement?.textContent
    ? JSON.parse(roleDataElement.textContent)
    : {};
  const roles = Array.isArray(roleData.roles) && roleData.roles.length > 0
    ? roleData.roles
    : ["Software Engineering Student"];
  const typeDelay = Number(roleData.typing?.typeDelay) || 125;
  const deleteDelay = Number(roleData.typing?.deleteDelay) || 90;
  const holdDelay = Number(roleData.typing?.holdDelay) || 1900;

  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (roleElement && !reduceMotion) {
    let roleIndex = 0;
    let charIndex = roles[0].length;
    let deleting = true;

    const tick = () => {
      const currentRole = roles[roleIndex];
      let delay = deleting ? deleteDelay : typeDelay;

      if (deleting) {
        charIndex -= 1;
        roleElement.textContent = currentRole.slice(0, charIndex);

        if (charIndex === 0) {
          deleting = false;
          roleIndex = (roleIndex + 1) % roles.length;
          delay = typeDelay;
        }
      } else {
        const nextRole = roles[roleIndex];
        charIndex += 1;
        roleElement.textContent = nextRole.slice(0, charIndex);

        if (charIndex === nextRole.length) {
          deleting = true;
          delay = holdDelay;
        }
      }

      window.setTimeout(tick, delay);
    };

    window.setTimeout(tick, holdDelay);
  }
</script>

<script>
  (() => {
    const canvas = document.getElementById("gridCanvas") as HTMLCanvasElement | null;
    if (!canvas) return;

    const smallScreen = window.matchMedia("(max-width: 1080px)").matches;
    if (smallScreen) return;

    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const gridSize = 50;
    const influenceRadius = 150;
    const maxDisplacement = reduceMotion ? 0 : 8;
    let mouseX = -1000;
    let mouseY = -1000;
    let animationFrameId: number | null = null;
    let isVisible = true;

    const resize = () => {
      const section = canvas.closest(".home-intro");
      const height = section instanceof HTMLElement ? section.offsetHeight : 600;
      const dpr = window.devicePixelRatio || 1;
      canvas.width = Math.floor(window.innerWidth * dpr);
      canvas.height = Math.floor(Math.min(height, 560) * dpr);
      canvas.style.height = `${Math.min(height, 560)}px`;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };

    const draw = () => {
      if (!isVisible) {
        animationFrameId = null;
        return;
      }

      const width = canvas.clientWidth;
      const height = canvas.clientHeight;
      ctx.clearRect(0, 0, width, height);
      ctx.strokeStyle = getComputedStyle(document.documentElement).getPropertyValue("--color-grid-stroke").trim() || "rgba(0, 0, 0, 0.075)";
      ctx.lineWidth = 1;

      for (let x = 0; x <= width; x += gridSize) {
        ctx.beginPath();
        for (let y = 0; y <= height; y += 5) {
          const dx = x - mouseX;
          const dy = y - mouseY;
          const distance = Math.sqrt(dx * dx + dy * dy);
          const offsetX = distance > 0 && distance < influenceRadius
            ? (dx / distance) * (1 - distance / influenceRadius) * maxDisplacement
            : 0;

          if (y === 0) {
            ctx.moveTo(x + offsetX, y);
          } else {
            ctx.lineTo(x + offsetX, y);
          }
        }
        ctx.stroke();
      }

      for (let y = 0; y <= height; y += gridSize) {
        ctx.beginPath();
        for (let x = 0; x <= width; x += 5) {
          const dx = x - mouseX;
          const dy = y - mouseY;
          const distance = Math.sqrt(dx * dx + dy * dy);
          const offsetY = distance > 0 && distance < influenceRadius
            ? (dy / distance) * (1 - distance / influenceRadius) * maxDisplacement
            : 0;

          if (x === 0) {
            ctx.moveTo(x, y + offsetY);
          } else {
            ctx.lineTo(x, y + offsetY);
          }
        }
        ctx.stroke();
      }

      animationFrameId = reduceMotion ? null : window.requestAnimationFrame(draw);
    };

    resize();
    draw();

    window.addEventListener("resize", () => {
      resize();
      if (animationFrameId === null) draw();
    });

    window.addEventListener("themechange", () => {
      if (animationFrameId === null) draw();
    });

    if (!reduceMotion) {
      document.addEventListener("mousemove", (event) => {
        const rect = canvas.getBoundingClientRect();
        mouseX = event.clientX - rect.left;
        mouseY = event.clientY - rect.top;
      });

      document.addEventListener("mouseleave", () => {
        mouseX = -1000;
        mouseY = -1000;
      });

      const observer = new IntersectionObserver((entries) => {
        isVisible = entries[0]?.isIntersecting ?? true;
        if (isVisible && animationFrameId === null) draw();
      });

      observer.observe(canvas);
    }
  })();
</script>

<style>
  .home-intro {
    position: relative;
    display: grid;
    min-height: clamp(500px, 62svh, 620px);
    place-items: center;
    overflow: hidden;
    padding: 46px 24px 44px;
    background: var(--color-home-bg);
    border-bottom: 1px solid var(--color-line);
    isolation: isolate;
  }

  .home-intro::before {
    content: none;
  }

  .home-intro::after {
    content: none;
  }

  #gridCanvas {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 0;
    width: 100%;
    height: 560px;
    pointer-events: none;
    opacity: var(--color-grid-opacity);
    image-rendering: -webkit-optimize-contrast;
    -webkit-mask-image: linear-gradient(-20deg, transparent 44%, rgba(0, 0, 0, 0.95));
    mask-image: linear-gradient(-20deg, transparent 44%, rgba(0, 0, 0, 0.95));
  }

  .home-hero {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(44px, 5vw, 76px);
    width: min(1180px, calc(100% - 32px));
    min-height: 360px;
  }

  .home-copy {
    display: flex;
    flex: 0 1 720px;
    flex-direction: column;
    align-items: flex-start;
    max-width: 720px;
    min-width: 0;
    text-align: left;
  }

  .home-avatar {
    display: flex;
    flex: 0 0 260px;
    align-items: center;
    justify-content: center;
  }

  .home-intro h1 {
    margin-bottom: 20px;
    color: var(--color-text);
    font-size: clamp(3rem, 4.8vw, 4.45rem);
    line-height: 1.1;
    font-weight: 820;
    letter-spacing: 0;
    white-space: nowrap;
  }

  :global(html[data-theme="dark"]) .home-intro h1 {
    color: rgba(232, 236, 244, 0.42);
  }

  .home-name-box {
    position: relative;
    display: inline-flex;
    align-items: center;
    margin-left: 8px;
    overflow: hidden;
    border: 2px dashed var(--color-home-name-border);
    border-radius: 10px;
    padding: 0.08em 0.24em 0.1em;
    background: linear-gradient(135deg, #f4f5f7 0%, #e7eaee 100%);
    box-shadow: 0 2px 8px rgba(128, 112, 205, 0.14);
    font-size: 0.94em;
    line-height: 1;
    vertical-align: baseline;
    transform: translateY(-0.025em);
  }

  .home-name-text {
    position: relative;
    z-index: 2;
    color: #202226;
    font-size: inherit;
    font-weight: 900;
    line-height: 1;
  }

  :global(html[data-theme="dark"]) .home-name-box {
    background: linear-gradient(135deg, #2d3748 0%, #1a202c 100%);
    box-shadow:
      0 2px 8px rgba(164, 151, 235, 0.16),
      0 8px 20px rgba(0, 0, 0, 0.26);
  }

  :global(html[data-theme="dark"]) .home-name-text {
    color: #f7fafc;
  }

  .home-name-box::before {
    content: "";
    position: absolute;
    top: 0;
    left: -110%;
    width: 100%;
    height: 100%;
    z-index: 1;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.95), transparent);
    transition: left 0.6s ease;
  }

  :global(html[data-theme="dark"]) .home-name-box::before {
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.38), transparent);
  }

  .home-name-box:hover::before {
    left: 110%;
  }

  .home-note {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    margin: 0 0 28px;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    padding: 5px 14px;
    background: var(--color-glass-bg);
    color: var(--color-muted);
    font-size: 0.9rem;
    box-shadow: var(--shadow-soft);
  }

  .home-role {
    min-height: 1.35em;
    margin-bottom: 28px;
    color: var(--color-muted);
    font-size: clamp(1.55rem, 2.8vw, 2.05rem);
    font-weight: 640;
    line-height: 1.25;
  }

  .dynamic-role {
    display: inline;
    color: var(--color-muted);
  }

  .type-caret {
    display: inline-block;
    width: 3px;
    height: 0.92em;
    margin-left: 4px;
    border-radius: 2px;
    background: var(--color-lilac);
    transform: translateY(0.1em);
    animation: caret-blink 900ms steps(2, start) infinite;
  }

  @keyframes caret-blink {
    50% {
      opacity: 0;
    }
  }

  .home-actions {
    justify-content: flex-start;
    flex-wrap: wrap;
    margin-top: 0;
  }

  .home-card-section {
    position: relative;
    overflow: hidden;
