            </svg>
            CSDN
          </a>
        </div>
      </div>
      <div class="home-avatar">
        <div class="profile-mark" aria-label="AloftVox">
          <div class="flip-glow-ultimate">
            <div class="flip-glow-ultimate-glow" aria-hidden="true"></div>
            <div
              class="flip-glow-ultimate-imgs"
              role="img"
              tabindex="0"
              aria-label="首页头像，悬停查看背面"
            >
              <img
                src="/images/home/profile-front.jpg"
                alt=""
                class="flip-glow-ultimate-back"
                loading="eager"
                fetchpriority="high"
                decoding="async"
                width="260"
                height="260"
              />
              <img
                src="/images/home/profile-back.jpg"
                alt=""
                class="flip-glow-ultimate-front"
                loading="eager"
