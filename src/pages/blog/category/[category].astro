---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostList from "../../../components/PostList.astro";
import { blogCategories } from "../../../data/categories";
import { sortPosts } from "../../../lib/posts";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const populatedCategoryKeys = new Set(posts.map((post) => post.data.category));

  return blogCategories.filter((category) => populatedCategoryKeys.has(category.key)).map((category) => ({
    params: { category: category.key },
    props: {
      category,
      posts: sortPosts(posts.filter((post) => post.data.category === category.key)),
    },
  }));
}

const { category, posts } = Astro.props;
const allPosts = await getCollection("blog");
const populatedCategoryKeys = new Set(allPosts.map((post) => post.data.category));
const visibleCategories = blogCategories.filter((item) => populatedCategoryKeys.has(item.key));
---

<BaseLayout title={category.label} description={category.description}>
  <header class="site-shell page-header">
    <p class="eyebrow">Category</p>
    <h1>{category.label}</h1>
    <p>{category.description}</p>
  </header>

  <section class="site-shell section-block">
    {
      visibleCategories.length >= 2 && (
        <div class="category-tabs" aria-label="文章分类">
          <a href="/blog/">全部</a>
          {visibleCategories.map((item) => (
            <a href={item.href} aria-current={item.key === category.key ? "page" : undefined}>
              {item.label}
            </a>
          ))}
        </div>
      )
    }
    <PostList posts={posts} />
  </section>
</BaseLayout>

<style>
  .category-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }

  .category-tabs a {
    border: 1px solid var(--color-line);
    border-radius: 7px;
    padding: 5px 10px;
    background: var(--color-surface);
    color: var(--color-muted);
    font-size: 0.94rem;
  }

  .category-tabs a:hover,
  .category-tabs a[aria-current="page"] {
    border-color: rgba(131, 118, 217, 0.34);
    background: var(--color-accent-soft);
    color: var(--color-accent-strong);
  }
</style>
