---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects } from "../../data/projects";
---

<BaseLayout title="项目" description="AloftVox 的项目记录。">
  <header class="site-shell page-header">
    <p class="eyebrow">Projects</p>
    <h1>项目</h1>
    <p>记录一些做过的项目，以及它们背后的实现、复盘和继续完善的方向。</p>
  </header>

  <section class="site-shell section-block">
    <ul class="simple-list project-list">
      {
        projects.map((project) => (
          <li>
            <a href={project.href}>
              <h2>{project.title}</h2>
              <p>{project.description}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .project-list a {
    display: block;
    margin: -8px;
    border-radius: 10px;
    padding: 8px;
    transition: background-color 150ms ease;
  }

  .project-list a:hover {
    background: var(--color-accent-soft);
  }

  .project-list a:hover h2 {
    color: var(--color-accent-strong);
    text-decoration: underline;
    text-decoration-color: rgba(90, 155, 216, 0.38);
    text-underline-offset: 5px;
  }
</style>