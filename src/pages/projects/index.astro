---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects } from "../../data/projects";
---

<BaseLayout title="项目" description="AloftVox 的项目记录。">
  <header class="site-shell page-header">
    <p class="eyebrow">Projects</p>
    <h1>项目</h1>
    <p>记录一些做过的项目，以及它们背后的实现、复盘和继续完善的方向。</p>
  </header>

  <section class="site-shell section-block">
    <ul class="simple-list project-list">
      {
        projects.map((project) => (
          <li>
            <a href={project.href}>
              <div class="project-heading">
                <h2>{project.title}</h2>
                <span>{project.status}</span>
              </div>
              <p>{project.description}</p>
              <ul aria-label="项目标签">
                {project.tags.map((tag) => <li>{tag}</li>)}
              </ul>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .project-list a {
    display: block;
    margin: -8px;
    border-radius: 10px;
    padding: 8px;
    transition: background-color 150ms ease;
  }

  .project-list a:hover {
    background: var(--color-accent-soft);
  }

  .project-list a:hover h2 {
    color: var(--color-accent-strong);
    text-decoration: underline;
    text-decoration-color: rgba(90, 155, 216, 0.38);
    text-underline-offset: 5px;
  }

  .project-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 20px;
  }

  .project-heading h2 {
    margin-bottom: 6px;
  }

  .project-heading span {
    flex: 0 0 auto;
    color: var(--color-subtle);
    font-size: 0.82rem;
  }

  .project-list ul {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin: 12px 0 0;
    padding: 0;
    list-style: none;
  }

  .project-list li li {
    border: 1px solid var(--color-line);
    border-radius: 7px;
    padding: 1px 7px;
    color: var(--color-subtle);
    font-size: 0.78rem;
  }

  @media (max-width: 520px) {
    .project-heading {
      align-items: flex-start;
      flex-direction: column;
      gap: 0;
    }
  }
</style>
