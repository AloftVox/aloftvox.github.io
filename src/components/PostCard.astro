---
import { getCategoryMeta } from "../data/categories";
import { formatDate, getPostUrl } from "../lib/posts";
import { getTagTone } from "../lib/tags";

const { post } = Astro.props;
const category = getCategoryMeta(post.data.category);
---

<article class="post-card">
  <a class="post-link" href={getPostUrl(post)}>
    <div class="post-meta">
      <span>{category.label}</span>
      <time datetime={post.data.pubDate.toISOString()}>
        {formatDate(post.data.pubDate)}
      </time>
    </div>
    <div class="post-summary">
      <h3>{post.data.title}</h3>
      <p>{post.data.description}</p>
      <ul class="post-tags" aria-label="标签">
        {post.data.tags.map((tag) => <li class={`tag-tone-${getTagTone(tag)}`}>{tag}</li>)}
      </ul>
    </div>
    <span class="post-arrow" aria-hidden="true">→</span>
  </a>
</article>

<style>
  .post-card {
    border-top: 1px solid var(--color-line);
  }

  .post-card:last-child {
    border-bottom: 1px solid var(--color-line);
  }

  .post-link {
    display: grid;
    grid-template-columns: 150px minmax(0, 1fr) auto;
    gap: 20px;
    align-items: center;
    margin: 0 -10px;
    padding: 20px 10px;
    border-radius: 8px;
    transition:
      background-color 150ms ease,
      color 150ms ease;
  }

  .post-link:hover {
    background: var(--color-accent-soft);
  }

  .post-link:hover h3 {
    color: var(--color-accent-strong);
    text-decoration: underline;
    text-decoration-color: rgba(90, 155, 216, 0.38);
    text-underline-offset: 5px;
  }

  .post-meta {
    display: flex;
    flex-direction: column;
    gap: 3px;
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .post-meta span {
    color: var(--color-accent-strong);
    font-weight: 650;
  }

  .post-summary {
    min-width: 0;
  }

  .post-summary h3 {
    margin-bottom: 6px;
    font-size: 1.12rem;
  }

  .post-summary p {
    margin: 0 0 10px;
    color: var(--color-muted);
    line-height: 1.65;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .post-tags li {
    border: 1px solid var(--color-line);
    border-radius: 7px;
    padding: 1px 7px;
    color: var(--color-subtle);
    font-size: 0.78rem;
    line-height: 1.55;
  }

  .post-arrow {
    color: var(--color-lilac);
    font-size: 1.25rem;
    transition: transform 150ms ease;
  }

  .post-link:hover .post-arrow {
    transform: translateX(3px);
  }

  @media (max-width: 720px) {
    .post-link {
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 12px;
      margin: 0 -8px;
      padding: 18px 8px;
    }

    .post-meta,
    .post-summary {
      grid-column: 1 / 2;
    }

    .post-arrow {
      grid-column: 2 / 3;
      grid-row: 1 / 3;
      align-self: center;
    }
  }
</style>
