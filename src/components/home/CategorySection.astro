---
import type { HomeOrbitCategory } from "../../data/home";
interface Props { categories: HomeOrbitCategory[]; }
const { categories } = Astro.props;
---

<section class="home-section category-section" aria-labelledby="category-title">
  <div class="home-shell">
    <div class="section-marker"><span>02</span></div>
    <header><p>Category Orbits</p><h2 id="category-title">Categories</h2><small>分类导航</small></header>
    <div class="category-grid">
      {categories.slice(0, 4).map((category, index) => (
        <a href={category.href} style={`--category-color:${category.color}`}>
          <canvas width="240" height="104" aria-hidden="true" data-category-orbit data-color={category.color} data-index={index}></canvas>
          <span>{category.count} posts</span>
          <h3>{category.name}</h3>
          <p>{category.description}</p>
        </a>
      ))}
    </div>
    <div class="explore-row"><a href="/blog/">Explore all categories <span aria-hidden="true">→</span></a></div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLCanvasElement>("[data-category-orbit]").forEach((canvas) => {
    const context = canvas.getContext("2d");
    if (!context) return;
    const color = canvas.dataset.color ?? "#64a8ff";
    const index = Number(canvas.dataset.index ?? 0);
    context.clearRect(0, 0, 240, 104);
    context.save();
    context.translate(118, 54);
    context.rotate(-0.16 + index * 0.05);
    context.strokeStyle = `${color}55`;
    context.lineWidth = 1;
    context.beginPath(); context.ellipse(0, 0, 88, 25, 0, 0, Math.PI * 2); context.stroke();
    context.strokeStyle = `${color}28`;
    context.beginPath(); context.ellipse(0, 0, 67, 17, 0.1, 0, Math.PI * 2); context.stroke();
    for (let point = 0; point < 6; point += 1) {
      const angle = point * 1.09 + index * 0.58;
      const radiusX = point % 2 ? 88 : 67;
      const radiusY = point % 2 ? 25 : 17;
      context.fillStyle = point === 0 ? color : `${color}bb`;
      context.beginPath(); context.arc(Math.cos(angle) * radiusX, Math.sin(angle) * radiusY, point === 0 ? 3.5 : 2, 0, Math.PI * 2); context.fill();
    }
    context.restore();
    context.fillStyle = color;
    context.beginPath(); context.arc(118, 54, 16, 0, Math.PI * 2); context.fill();
    context.strokeStyle = "rgba(255,255,255,.76)"; context.lineWidth = 1.2;
    context.beginPath(); context.arc(118, 54, 10, 0, Math.PI * 2); context.stroke();
  });
</script>

<style>
  .home-section{background:var(--home-paper);color:var(--home-text);transition:background-color 220ms ease,color 220ms ease}.home-shell{position:relative;width:min(1280px,calc(100% - 80px));margin:0 auto;padding:64px 0 42px 68px}.section-marker{position:absolute;top:68px;bottom:0;left:0;width:24px;border-left:1px solid var(--home-line)}.section-marker span{position:absolute;top:-4px;left:-9px;color:var(--home-subtle);font:500 .76rem Georgia,serif;background:var(--home-paper);padding:0 4px}header p,header small{margin:0;color:var(--home-subtle);font-size:.75rem}header h2{margin:4px 0 1px;font:500 clamp(2.15rem,3vw,3.15rem)/1.02 Georgia,"Microsoft YaHei",serif}.category-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:36px;margin-top:34px}.category-grid>a{display:block;min-width:0;color:var(--home-text)}.category-grid canvas{display:block;width:100%;height:auto;aspect-ratio:250/106;transition:filter 180ms ease,transform 180ms ease}.category-grid span{color:var(--category-color);font-size:.7rem}.category-grid h3{margin:8px 0 5px;color:var(--category-color);font:500 1.02rem Georgia,"Microsoft YaHei",serif}.category-grid p{max-width:240px;margin:0;color:var(--home-muted);font-size:.78rem;line-height:1.65}.explore-row{display:flex;justify-content:center;margin-top:38px}.explore-row a{display:inline-flex;align-items:center;justify-content:center;min-height:44px;border:1px solid var(--home-line);border-radius:6px;padding:7px 16px;color:var(--home-muted);background:color-mix(in srgb,var(--home-surface) 58%,transparent);font-size:.78rem}.category-grid>a:hover canvas{filter:drop-shadow(0 0 12px color-mix(in srgb,var(--category-color) 28%,transparent));transform:translateY(-2px)}@media(max-width:820px){.category-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:620px){.home-shell{width:min(100% - 28px,1120px);padding:46px 0 28px}.section-marker{display:none}.category-grid{grid-template-columns:1fr 1fr;gap:28px 16px}.category-grid p{font-size:.74rem}}
</style>
