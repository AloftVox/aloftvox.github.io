---
import type { OrbitNode, OrbitSourceLink } from "../../lib/orbitNodes";
import type { HomeArticle } from "../../data/home";
import { siCsdn, siGitee, siGithub, type SimpleIcon } from "simple-icons";
import FeaturedOrbitArticle from "./FeaturedOrbitArticle.astro";

interface Props {
  orbitNodes: OrbitNode[];
  socialLinks: OrbitSourceLink[];
  introLines: string[];
  heroRoles: string[];
  nodePreviews: Record<string, HomeArticle>;
}

const { orbitNodes, socialLinks, introLines, heroRoles, nodePreviews } = Astro.props;
const featuredPreview = nodePreviews["category-development"] ?? Object.values(nodePreviews)[0];
const socialIconById: Record<string, SimpleIcon> = {
  github: siGithub,
  gitee: siGitee,
  csdn: siCsdn,
};
---

<script is:inline>
  document.documentElement.dataset.orbitIntro = "running";
</script>

<section class="orbit-hero" aria-labelledby="orbit-title" data-orbit-hero data-intro-state="pending" data-intro-running>
  <div class="orbit-backdrop" aria-hidden="true"></div>
  <div class="orbit-stage" data-orbit-stage>
    <canvas data-orbit-v2-canvas aria-hidden="true"></canvas>
  </div>

  <div class="orbit-hit-layer" aria-label="可探索星图节点">
    <button class="avatar-hit-target" type="button" data-avatar-target aria-label="切换首页星际影像"></button>
    {orbitNodes.map((node) => (
      <a
      class={`orbit-node-hotspot orbit-node-hotspot-${node.type}`}
      href={node.href}
      style={`--node-color:${node.color}`}
      data-orbit-node-hotspot={node.id}
      data-label-side={node.id === "category-design-ux" ? "right" : node.angleSeed > 0.5 ? "left" : "right"}
      aria-label={node.title}
    >
        <span class="sr-node-label">{node.title}</span>
        {(node.type === "category" || node.type === "post" || node.type === "project") && (
          <span class="visible-node-label" aria-hidden="true">
            <strong>{node.type === "post" ? "文章" : node.type === "project" ? "项目" : node.title}</strong>
            <small>{node.type === "category" ? node.meta : node.title}</small>
          </span>
        )}
      </a>
    ))}
  </div>

  <div class="hero-topline site-shell" aria-hidden="true">
    <span>AloftVox</span>
    <span>Orbit Library / Live Index</span>
  </div>

  <div class="orbit-copy site-shell">
    <p class="orbit-kicker">Interactive Knowledge Orbit</p>
    <h1 id="orbit-title" class="orbit-particle-title" aria-label="AloftVox">
      <span>AloftVox</span>
      <canvas data-orbit-title-particles aria-hidden="true"></canvas>
    </h1>
    <p class="hero-manifesto">
      <span data-orbit-role-text>{heroRoles[0]}</span><span class="type-caret" aria-hidden="true"></span>
    </p>
    <div class="intro-stack" aria-label="首页叙事">
      {introLines.map((line) => <p>{line}</p>)}
    </div>
  </div>

  {featuredPreview && <FeaturedOrbitArticle article={featuredPreview} />}

  <div class="hero-actions">
    <div class="intro-controls" aria-label="开场动画控制">
      <button type="button" data-intro-skip>跳过动画</button>
    </div>
    <nav class="social-dock" aria-label="外部链接">
      {socialLinks.map((link) => {
        const icon = socialIconById[link.id];
        return (
          <a
            href={link.href}
            target="_blank"
            rel="noreferrer"
            data-social-node={`link-${link.id}`}
            aria-label={link.title}
            title={link.title}
          >
            {icon && (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d={icon.path}></path>
              </svg>
            )}
            <span>{link.title}</span>
          </a>
        );
      })}
    </nav>
  </div>

  <a class="scroll-cue" href="#orbit-index" aria-label="浏览最新文章">
    <span>最新文章</span>
  </a>

  <p class="sr-only" role="status" data-intro-status>正在生成知识星图</p>
</section>

<script id="orbit-hero-data" type="application/json" set:html={JSON.stringify({ nodes: orbitNodes, roles: heroRoles, previews: nodePreviews })} />

<script>
  import { createOrbitIntro } from "../../scripts/orbit-intro";

  const root = document.querySelector<HTMLElement>("[data-orbit-hero]");
  const stage = root?.querySelector<HTMLElement>("[data-orbit-stage]");
  const canvas = root?.querySelector<HTMLCanvasElement>("[data-orbit-v2-canvas]");
  const avatarTarget = root?.querySelector<HTMLElement>("[data-avatar-target]");
  const dataElement = document.getElementById("orbit-hero-data");
  const payload = dataElement?.textContent ? JSON.parse(dataElement.textContent) : { nodes: [], roles: [] };

  if (root && stage && canvas && avatarTarget && Array.isArray(payload.nodes)) {
    await new Promise<void>((resolve) => {
      if ("requestIdleCallback" in window) {
        window.requestIdleCallback(() => resolve(), { timeout: 600 });
      } else {
        window.setTimeout(resolve, 0);
      }
    });
    const { createOrbitScene } = await import("../../scripts/orbit-scene");
    const mobile = window.matchMedia("(max-width: 760px)").matches;
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const status = root.querySelector<HTMLElement>("[data-intro-status]");
    const card = root.querySelector<HTMLElement>("[data-active-node-card]");
    const roleElement = root.querySelector<HTMLElement>("[data-orbit-role-text]");
    let activeNodeId = "";
    let coarseArmedId = "";
    let clearTimer = 0;
    let roleTimer = 0;
    let titlePointerX = 0;
    let titlePointerY = 0;

    const intro = createOrbitIntro({
      root,
      mobile,
      reducedMotion,
      onFinish: (reason) => {
        document.documentElement.removeAttribute("data-orbit-intro");
        if (status) status.textContent = reason === "skipped" ? "已跳过开场动画" : "知识星图已生成";
      },
    });

    const titleCanvas = root.querySelector<HTMLCanvasElement>("[data-orbit-title-particles]");
    const title = root.querySelector<HTMLElement>(".orbit-particle-title");
    const titleContext = titleCanvas?.getContext("2d", { willReadFrequently: true });
    let titleMaskSurface: HTMLCanvasElement | null = null;
    let titleParticles: Array<{ tx: number; ty: number; ox: number; oy: number; size: number; delay: number; depth: number; kind: "body" | "highlight" | "chroma" | "drift" }> = [];

    const buildTitleParticles = () => {
      if (!titleCanvas || !title || !titleContext) return;
      const rect = title.getBoundingClientRect();
      const width = Math.max(250, Math.round(rect.width));
      const height = Math.max(104, Math.round(rect.height));
      const dpr = mobile ? 1 : Math.min(window.devicePixelRatio || 1, 1.5);
      titleCanvas.width = Math.round(width * dpr);
      titleCanvas.height = Math.round(height * dpr);
      titleCanvas.style.width = `${width}px`;
      titleCanvas.style.height = `${height}px`;
      titleContext.setTransform(dpr, 0, 0, dpr, 0, 0);
      titleContext.clearRect(0, 0, width, height);

      const maskSurface = document.createElement("canvas");
      maskSurface.width = width;
      maskSurface.height = height;
      const maskContext = maskSurface.getContext("2d", { willReadFrequently: true });
      if (!maskContext) return;

      const baseSize = 120;
      const paddingX = mobile ? 10 : 18;
      const paddingY = mobile ? 8 : 12;
      maskContext.font = `500 ${baseSize}px Georgia, Times New Roman, serif`;
      const measured = maskContext.measureText("AloftVox").width;
      const availableWidth = Math.max(1, width - paddingX * 2);
      const availableHeight = Math.max(1, height - paddingY * 2);
      const fontSize = Math.min(availableHeight * 0.82, availableWidth / Math.max(measured, 1) * baseSize * 0.985);
      maskContext.font = `500 ${fontSize}px Georgia, Times New Roman, serif`;
      maskContext.textAlign = "left";
      maskContext.textBaseline = "middle";
      maskContext.fillStyle = "#ffffff";
      maskContext.fillText("AloftVox", paddingX, height * 0.51);
      titleMaskSurface = maskSurface;
      const pixels = maskContext.getImageData(0, 0, width, height);
      const gap = mobile ? 2.18 : 1.82;
      const sourceRect = avatarTarget.getBoundingClientRect();
      const sourceX = sourceRect.width ? sourceRect.left + sourceRect.width / 2 - rect.left : width * 1.18;
      const sourceY = sourceRect.height ? sourceRect.top + sourceRect.height / 2 - rect.top : height * 0.52;
      const next = [];
      let randomState = 73129;
      const random = () => {
        randomState = (randomState * 1664525 + 1013904223) >>> 0;
        return randomState / 4294967296;
      };
      for (let sampleY = paddingY; sampleY < height - paddingY; sampleY += gap) {
        for (let sampleX = paddingX; sampleX < width - paddingX; sampleX += gap) {
          const x = Math.min(width - 1, Math.max(0, Math.round(sampleX + (random() - 0.5) * gap * 0.28)));
          const y = Math.min(height - 1, Math.max(0, Math.round(sampleY + (random() - 0.5) * gap * 0.28)));
          const alpha = pixels.data[(y * width + x) * 4 + 3];
          if (alpha < 72) continue;
          const depth = 0.12 + random() * 0.88;
          const particleRoll = random();
          const kind = particleRoll < 0.065 ? "highlight" : particleRoll < 0.26 ? "chroma" : "body";
          next.push({
            tx: x + (random() - 0.5) * 0.72,
            ty: y + (random() - 0.5) * 0.72,
            ox: sourceX + (random() - 0.5) * (120 + depth * 120),
            oy: sourceY + (random() - 0.5) * (70 + depth * 100),
            size: kind === "highlight" ? 0.96 + random() * 0.68 : kind === "chroma" ? 0.38 + random() * 0.56 : 0.19 + Math.pow(random(), 1.65) * 0.64,
            delay: random(),
            depth,
            kind,
          });
          if (random() < 0.005) {
            const driftDirection = random() > 0.5 ? 1 : -1;
            next.push({
              tx: x + driftDirection * (6 + random() * 14),
              ty: y + (random() - 0.5) * 12,
              ox: sourceX + (random() - 0.5) * 190,
              oy: sourceY + (random() - 0.5) * 100,
              size: 0.28 + random() * 0.44,
              delay: random(),
              depth: 0.35 + random() * 0.45,
              kind: "drift",
            });
          }
        }
      }
      titleParticles = next;
      title.dataset.particlesReady = "true";
    };

    const renderTitle = (progress: number, elapsed: number) => {
      if (!titleCanvas || !titleContext) return;
      const width = titleCanvas.clientWidth || 1;
      const height = titleCanvas.clientHeight || 1;
      titleContext.clearRect(0, 0, width, height);
      if (titleMaskSurface) {
        titleContext.save();
        titleContext.globalCompositeOperation = "source-over";
        titleContext.globalAlpha = 0.06 * Math.min(1, progress * 1.25);
        titleContext.filter = "blur(1.55px)";
        titleContext.drawImage(titleMaskSurface, 0, 0, width, height);
        titleContext.restore();
      }
      titleContext.globalCompositeOperation = "lighter";
      titleParticles.forEach((particle) => {
        const local = reducedMotion ? 1 : Math.min(1, Math.max(0, (progress - particle.delay * 0.2) / 0.8));
        const eased = 1 - Math.pow(1 - local, 3);
        const driftAmount = particle.kind === "drift" ? 0.2 : particle.kind === "highlight" ? 0.1 : particle.kind === "chroma" ? 0.07 : 0.04;
        const drift = reducedMotion ? 0 : Math.sin(elapsed * (0.45 + particle.depth * 0.42) + particle.delay * 17) * driftAmount;
        const depthOffsetX = titlePointerX * (particle.depth - 0.38) * (mobile ? 1.4 : 4.8);
        const depthOffsetY = titlePointerY * (particle.depth - 0.38) * (mobile ? 0.9 : 2.8);
        const x = particle.ox + (particle.tx - particle.ox) * eased + drift + depthOffsetX;
        const verticalDrift = particle.kind === "drift" ? 0.22 : particle.kind === "highlight" ? 0.1 : particle.kind === "chroma" ? 0.07 : 0.035;
        const y = particle.oy + (particle.ty - particle.oy) * eased + Math.cos(elapsed + particle.delay * 13) * verticalDrift + depthOffsetY;
        const depthOpacity = 0.28 + particle.depth * 0.72;
        const voxEmphasis = Math.max(0, Math.min(1, (particle.tx / width - 0.48) / 0.46));
        const alpha = particle.kind === "highlight" ? 1 : particle.kind === "chroma" ? 0.94 + voxEmphasis * 0.04 : particle.kind === "drift" ? 0.22 : 0.88;
        const lilacHighlight = particle.kind === "highlight" && particle.delay > 0.58;
        const blueChroma = particle.kind === "chroma" && particle.delay < 0.57 + voxEmphasis * 0.1;
        const bodyLilac = particle.kind === "body" && particle.depth > 0.44 && (particle.delay > 0.74 || (voxEmphasis > 0.45 && particle.delay > 0.64));
        const red = particle.kind === "highlight" ? (lilacHighlight ? 246 : 255) : particle.kind === "chroma" ? (blueChroma ? 137 : 205) : 207 + Math.round(particle.depth * 32) + (bodyLilac ? 8 : 0);
        const green = particle.kind === "highlight" ? (lilacHighlight ? 226 : 240) : particle.kind === "chroma" ? (blueChroma ? 190 : 184) : 220 + Math.round(particle.depth * 25) - (bodyLilac ? 5 : 0);
        const blue = particle.kind === "drift" ? 250 : 255;
        if (particle.kind === "highlight" || particle.kind === "chroma") {
          titleContext.fillStyle = particle.kind === "chroma"
            ? `rgba(${blueChroma ? 98 : 202}, ${blueChroma ? 165 : 168}, 255, ${eased * (0.38 + voxEmphasis * 0.05) * particle.depth})`
            : `rgba(${lilacHighlight ? 233 : 255}, ${lilacHighlight ? 199 : 224}, 255, ${eased * 0.32 * particle.depth})`;
          titleContext.beginPath();
          titleContext.arc(x, y, particle.size * (particle.kind === "chroma" ? 2.52 : 2.02 + particle.depth * 0.62), 0, Math.PI * 2);
          titleContext.fill();
        }
        titleContext.fillStyle = `rgba(${red}, ${green}, ${blue}, ${eased * alpha * depthOpacity})`;
        titleContext.beginPath();
        titleContext.arc(x, y, particle.size, 0, Math.PI * 2);
        titleContext.fill();
      });
    };

    const scene = await createOrbitScene({
      root,
      stage,
      canvas,
      avatarProxy: avatarTarget,
      nodes: payload.nodes,
      intro,
      mobile,
      reducedMotion,
      onFrame: (frame, elapsed) => renderTitle(frame.title, elapsed),
    });

    const nodeById = new Map(payload.nodes.map((node: any) => [node.id, node]));
    const cancelClear = () => {
      if (!clearTimer) return;
      window.clearTimeout(clearTimer);
      clearTimer = 0;
    };

    const clearNode = () => {
      cancelClear();
      activeNodeId = "";
      coarseArmedId = "";
      scene.setActiveNode(null);
      root.querySelectorAll<HTMLElement>("[data-node-active]").forEach((target) => {
        target.removeAttribute("data-node-active");
      });
      card?.removeAttribute("data-card-visible");
      card?.style.removeProperty("--card-x");
      card?.style.removeProperty("--card-y");
      card?.style.removeProperty("--card-accent");
    };

    const scheduleClear = () => {
      cancelClear();
      clearTimer = window.setTimeout(clearNode, 180);
    };

    const showNode = (nodeId: string, source: HTMLElement) => {
      const node: any = nodeById.get(nodeId);
      if (!node || !card) return;
      cancelClear();
      activeNodeId = nodeId;
      scene.setActiveNode(nodeId);
      root.querySelectorAll<HTMLElement>("[data-node-active]").forEach((target) => {
        target.removeAttribute("data-node-active");
      });
      source.setAttribute("data-node-active", "");
      const preview = payload.previews?.[nodeId];
      card.setAttribute("href", preview?.href ?? node.href);
      card.setAttribute("aria-label", `打开 ${preview?.title ?? node.title}`);
      card.style.setProperty("--card-accent", node.color);
      const nodeTypeLabel = node.type === "post" ? "文章" : node.type === "project" ? "项目" : node.type === "category" ? "分类" : "链接";
      card.querySelector<HTMLElement>("[data-active-node-type]")!.textContent = nodeTypeLabel;
      card.querySelector<HTMLElement>("[data-active-node-title]")!.textContent = preview?.title ?? node.title;
      card.querySelector<HTMLElement>("[data-active-node-meta]")!.textContent = node.meta;
      card.querySelector<HTMLElement>("[data-active-node-description]")!.textContent = preview?.description ?? node.description;
      card.querySelector<HTMLElement>("[data-active-node-date]")!.textContent = preview?.date ?? "";
      card.querySelector<HTMLElement>("[data-active-node-reading]")!.textContent = preview?.readingTime ?? "";
      const tagList = card.querySelector<HTMLElement>("[data-active-node-tags]");
      if (tagList) {
        tagList.replaceChildren(...(preview?.tags ?? []).map((tag: string) => {
          const item = document.createElement("li");
          item.textContent = tag;
          return item;
        }));
      }
      const heroRect = root.getBoundingClientRect();
      const sourceRect = source.getBoundingClientRect();
      const cardWidth = Math.min(card.offsetWidth || 340, 340);
      const cardHeight = card.offsetHeight || 190;
      const x = sourceRect.left + sourceRect.width / 2 - heroRect.left;
      const y = sourceRect.top + sourceRect.height / 2 - heroRect.top;
      const avatarRect = avatarTarget.getBoundingClientRect();
      const avatarLeft = avatarRect.left - heroRect.left;
      const avatarRight = avatarRect.right - heroRect.left;
      const avatarTop = avatarRect.top - heroRect.top;
      const avatarBottom = avatarRect.bottom - heroRect.top;
      const headerBottom = document.querySelector<HTMLElement>(".site-header")?.getBoundingClientRect().bottom ?? 68;
      const boundaryTop = Math.max(82, headerBottom - heroRect.top + 14);
      const boundary = {
        left: 18,
        right: Math.max(18, heroRect.width - cardWidth - 18),
        top: boundaryTop,
        bottom: Math.max(boundaryTop, heroRect.height - cardHeight - 30),
      };
      const nodeRadius = Math.max(sourceRect.width, sourceRect.height) / 2;
      const cardGap = 16;
      const clampPosition = (value: number, min: number, max: number) => Math.max(min, Math.min(max, value));
      const makeRect = (left: number, top: number, width: number, height: number, padding = 0) => ({
        left: left - padding,
        top: top - padding,
        right: left + width + padding,
        bottom: top + height + padding,
      });
      const overlapRatio = (
        cardRect: { left: number; top: number; right: number; bottom: number },
        protectedRect: { left: number; top: number; right: number; bottom: number },
      ) => {
        const overlapWidth = Math.max(0, Math.min(cardRect.right, protectedRect.right) - Math.max(cardRect.left, protectedRect.left));
        const overlapHeight = Math.max(0, Math.min(cardRect.bottom, protectedRect.bottom) - Math.max(cardRect.top, protectedRect.top));
        return (overlapWidth * overlapHeight) / Math.max(1, cardWidth * cardHeight);
      };
      const toHeroRect = (rect: DOMRect, padding = 0) => makeRect(
        rect.left - heroRect.left,
        rect.top - heroRect.top,
        rect.width,
        rect.height,
        padding,
      );
      const avatarBounds = makeRect(avatarLeft, avatarTop, avatarRight - avatarLeft, avatarBottom - avatarTop, 18);
      const sourceBounds = makeRect(
        sourceRect.left - heroRect.left,
        sourceRect.top - heroRect.top,
        sourceRect.width,
        sourceRect.height,
        8,
      );
      const actionsRect = root.querySelector<HTMLElement>(".hero-actions")?.getBoundingClientRect();
      const actionsBounds = actionsRect ? toHeroRect(actionsRect, 18) : null;
      const copyBounds = Array.from(root.querySelectorAll<HTMLElement>(
        ".orbit-kicker, .orbit-particle-title, .hero-manifesto, .intro-stack",
      )).map((element) => toHeroRect(element.getBoundingClientRect(), 10));
      const awayFromAvatar = x < (avatarLeft + avatarRight) / 2 ? "left" : "right";
      const rawCandidates = {
        left: { x: x - nodeRadius - cardGap - cardWidth, y: y - cardHeight / 2 },
        right: { x: x + nodeRadius + cardGap, y: y - cardHeight / 2 },
        above: { x: x - cardWidth / 2, y: y - nodeRadius - cardGap - cardHeight },
        below: { x: x - cardWidth / 2, y: y + nodeRadius + cardGap },
      };
      const candidateOrder = [awayFromAvatar, "above", "below", awayFromAvatar === "left" ? "right" : "left"] as const;
      const candidates = candidateOrder.map((side, index) => {
        const raw = rawCandidates[side];
        const candidateX = clampPosition(raw.x, boundary.left, boundary.right);
        const candidateY = clampPosition(raw.y, boundary.top, boundary.bottom);
        const rect = makeRect(candidateX, candidateY, cardWidth, cardHeight);
        const edgeX = clampPosition(x, rect.left, rect.right);
        const edgeY = clampPosition(y, rect.top, rect.bottom);
        const proximity = Math.hypot(edgeX - x, edgeY - y);
        const collisionPenalty = overlapRatio(rect, avatarBounds) * 5200
          + overlapRatio(rect, sourceBounds) * 6200
          + (actionsBounds ? overlapRatio(rect, actionsBounds) * 5600 : 0)
          + copyBounds.reduce((score, copyRect) => score + overlapRatio(rect, copyRect) * 2600, 0);
        const clampPenalty = Math.hypot(candidateX - raw.x, candidateY - raw.y) * 0.8;
        return { x: candidateX, y: candidateY, score: proximity + collisionPenalty + clampPenalty + index * 2 };
      });
      const bestCandidate = candidates.reduce((best, candidate) => candidate.score < best.score ? candidate : best);
      const cardX = bestCandidate.x;
      const cardY = bestCandidate.y;
      card.style.setProperty("--card-x", `${cardX}px`);
      card.style.setProperty("--card-y", `${cardY}px`);
      card.setAttribute("data-card-visible", "true");
    };

    root.querySelectorAll<HTMLElement>("[data-orbit-node-hotspot]").forEach((target) => {
      const nodeId = target.dataset.orbitNodeHotspot ?? "";
      target.addEventListener("mouseenter", () => showNode(nodeId, target));
      target.addEventListener("focus", () => showNode(nodeId, target));
      target.addEventListener("mouseleave", scheduleClear);
      target.addEventListener("blur", scheduleClear);
      target.addEventListener("click", (event) => {
        if (!window.matchMedia("(hover: none)").matches || coarseArmedId === nodeId) return;
        event.preventDefault();
        coarseArmedId = nodeId;
        showNode(nodeId, target);
      });
    });

    card?.addEventListener("mouseenter", cancelClear);
    card?.addEventListener("focus", cancelClear);
    card?.addEventListener("mouseleave", scheduleClear);
    card?.addEventListener("blur", scheduleClear);

    let avatarPointerInside = false;
    avatarTarget.addEventListener("mouseenter", () => {
      avatarPointerInside = true;
      scene.flipAvatar();
    });
    avatarTarget.addEventListener("mouseleave", () => {
      avatarPointerInside = false;
    });
    avatarTarget.addEventListener("click", (event) => {
      if (!avatarPointerInside || event.detail === 0) scene.flipAvatar();
    });

    const startRoleLoop = () => {
      if (!roleElement || reducedMotion || roleTimer) return;
      const roles = Array.isArray(payload.roles) && payload.roles.length ? payload.roles : ["Orbit Library"];
      const roleGlyphs = roles.map((role: string) => Array.from(role));
      let index = 0;
      let visibleGlyphs = 0;
      let deleting = false;

      const typeNextGlyph = () => {
        const glyphs = roleGlyphs[index] ?? [];
        if (deleting) {
          visibleGlyphs = Math.max(0, visibleGlyphs - 1);
          roleElement.textContent = glyphs.slice(0, visibleGlyphs).join("");
          if (visibleGlyphs === 0) {
            deleting = false;
            index = (index + 1) % roles.length;
            roleTimer = window.setTimeout(typeNextGlyph, 360);
            return;
          }
          roleTimer = window.setTimeout(typeNextGlyph, 28);
          return;
        }

        visibleGlyphs = Math.min(glyphs.length, visibleGlyphs + 1);
        roleElement.textContent = glyphs.slice(0, visibleGlyphs).join("");
        if (visibleGlyphs === glyphs.length) {
          deleting = true;
          roleTimer = window.setTimeout(typeNextGlyph, 1900);
          return;
        }

        const glyph = glyphs[visibleGlyphs - 1] ?? "";
        const punctuationPause = /[,.!?，。！？]/.test(glyph) ? 150 : 0;
        roleTimer = window.setTimeout(typeNextGlyph, 54 + punctuationPause);
      };

      roleElement.textContent = "";
      roleTimer = window.setTimeout(typeNextGlyph, 320);
    };

    window.addEventListener("aloftvox:orbit-intro-complete", startRoleLoop, { once: true });
    if (intro.isFinished()) startRoleLoop();
    root.querySelector<HTMLElement>("[data-intro-skip]")?.addEventListener("click", () => scene.skip());
    window.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") return;
      if (!intro.isFinished()) scene.skip();
      else clearNode();
    });

    const resizeObserver = new ResizeObserver(buildTitleParticles);
    if (title) resizeObserver.observe(title);
    window.requestAnimationFrame(buildTitleParticles);

    root.addEventListener("pointermove", (event) => {
      const rect = root.getBoundingClientRect();
      titlePointerX = ((event.clientX - rect.left) / Math.max(rect.width, 1) - 0.5) * 2;
      titlePointerY = ((event.clientY - rect.top) / Math.max(rect.height, 1) - 0.5) * 2;
      title?.style.setProperty("--title-rotate-y", `${titlePointerX * 4.2}deg`);
      title?.style.setProperty("--title-rotate-x", `${titlePointerY * -2.2}deg`);
    }, { passive: true });
    root.addEventListener("pointerleave", () => {
      titlePointerX = 0;
      titlePointerY = 0;
      title?.style.setProperty("--title-rotate-y", "0deg");
      title?.style.setProperty("--title-rotate-x", "0deg");
    });

    window.addEventListener("pagehide", () => {
      window.clearTimeout(roleTimer);
      resizeObserver.disconnect();
      scene.dispose();
    });
  } else {
    document.documentElement.removeAttribute("data-orbit-intro");
    root?.removeAttribute("data-intro-running");
    if (root) root.dataset.introState = "settled";
  }
</script>

