<section class="subscribe-section" aria-labelledby="subscribe-title">
  <div class="subscribe-shell"><div><p>Stay in Orbit</p><h2 id="subscribe-title">保持连接</h2><span>订阅更新，获取最新文章与项目动态。</span></div><form data-subscribe-form><label class="sr-only" for="subscribe-email">邮箱地址</label><input id="subscribe-email" type="email" name="email" placeholder="输入你的邮箱" required autocomplete="email" /><button type="submit">Subscribe</button><small role="status" data-subscribe-status></small></form></div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-subscribe-form]");
  const status = form?.querySelector<HTMLElement>("[data-subscribe-status]");
  form?.addEventListener("submit", (event) => { event.preventDefault(); if (!form.reportValidity()) return; if (status) status.textContent = "已记录，感谢订阅。"; form.reset(); });
</script>

<style>
  .subscribe-section{background:#fbfaf7;color:#1b1c20}.subscribe-shell{display:grid;grid-template-columns:minmax(0,1fr) minmax(380px,540px);gap:48px;align-items:end;width:min(1212px,calc(100% - 80px));margin:0 auto;border-top:1px solid #d8dbe0;padding:38px 0 48px}.subscribe-shell p{margin:0;color:#9a7a4e;font-size:.7rem;text-transform:uppercase}.subscribe-shell h2{margin:4px 0 5px;font:500 1.8rem Georgia,"Microsoft YaHei",serif}.subscribe-shell span{color:#7b7e85;font-size:.78rem}.subscribe-shell form{position:relative;display:grid;grid-template-columns:1fr auto}.subscribe-shell input,.subscribe-shell button{min-height:42px;border:1px solid #d6d6d4;font:inherit;font-size:.8rem}.subscribe-shell input{border-radius:6px 0 0 6px;padding:8px 12px;background:#fff;color:#27282c}.subscribe-shell button{border-left:0;border-radius:0 6px 6px 0;padding:8px 20px;background:#171920;color:#fff;cursor:pointer}.subscribe-shell small{position:absolute;top:calc(100% + 5px);left:0;color:#54734f;font-size:.7rem}.sr-only{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0)}@media(max-width:720px){.subscribe-shell{grid-template-columns:1fr;gap:18px;width:min(100% - 28px,1062px)} }
</style>
